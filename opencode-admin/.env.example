# OpenCode Admin runtime configuration
NODE_ENV=production
TZ=Europe/Amsterdam
API_PORT=3001
LOG_LEVEL=info

# Base URL of this admin site
OPENCODE_ADMIN_BASE_URL=https://opencode.2631.eu/manage

# Target stack managed by the control plane
OPENCODE_TARGET_STACK_PATH=/opt/stacks/opencode-dev
OPENCODE_TARGET_ENV_PATH=/opt/stacks/opencode-dev/.env

# Optional: also restart opencode-dev after apply
OPENCODE_APPLY_RESTART=false

# Optional: repo-based auto updater
OPENCODE_UPDATER_ENABLED=false
OPENCODE_UPDATER_REPO_URL=https://github.com/Daltonganger/OpencodeDocker.git
OPENCODE_UPDATER_BRANCH=main
OPENCODE_UPDATER_INTERVAL_HOURS=6
OPENCODE_UPDATER_REPO_DIR=/var/lib/opencode-updater/repo
