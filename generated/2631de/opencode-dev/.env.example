# Copy this file to /opt/stacks/opencode-dev/.env and fill the placeholders.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
NANOGPT_API_KEY=
NVIDIA_API_KEY=
KILO_GATEWAY_API_KEY=
CHAT2631_API_KEY=
CODEXLB_API_KEY=
ZAI_API_KEY=
CONTEXT7_API_KEY=
TAVILY_API_KEY=
BRAVE_API_KEY=
QWEN_CLIENT_ID=
QWEN_CLIENT_SECRET=
SFTPGO_WEBDAV_USERNAME=webdav
SFTPGO_WEBDAV_PASSWORD=PASTE_HERE
PUID=1000
PGID=1000
UMASK=002
TZ=Europe/Amsterdam

# Model routing
OPENCODE_MODEL=anthropic/claude-3-5-sonnet-latest
OPENCODE_SMALL_MODEL=openai/gpt-4o-mini
PRIMARY_REASONING_MODEL=anthropic/claude-3-5-sonnet-latest
FAST_CODER_MODEL=openai/gpt-4o-mini
RESEARCH_MODEL=openrouter/openai/gpt-4o-mini
BUDGET_MODEL=openrouter/openai/gpt-4o-mini

# Provider base URLs / endpoints
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
NANOGPT_BASE_URL=https://nanoproxy.2631.eu/v1
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
KILO_GATEWAY_BASE_URL=https://api.kilo.ai/api/gateway
CHAT2631_BASE_URL=https://chat.2631.eu/v1
CODEXLB_BASE_URL=https://codex.2631.eu/v1
ZAI_BASE_URL=https://api.z.ai/api/paas/v4/
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
